---
/**
 * PageLayout.astro — Generic content page wrapper.
 *
 * Adds a page header (title + optional subtitle) with view-transition-name
 * for animated title morphing, and constrains content width.
 * Used by: about, contact, search, and other non-article pages.
 */
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  activeNav?: string;
  /** Subtitle shown below the page title */
  subtitle?: string;
}

const { title, description, ogImage, activeNav, subtitle } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  activeNav={activeNav}
>
  <div class="wide-container pt-12 md:pt-16">
    <header class="mb-12 border-b border-[var(--color-border)] pb-8">
      <h1 class="vt-page-title font-display text-4xl font-semibold tracking-[-0.02em] md:text-[52px] leading-[1.08]">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-4 max-w-xl text-base text-[var(--color-text-secondary)] leading-relaxed">
          {subtitle}
        </p>
      )}
    </header>
    <slot />
  </div>
</BaseLayout>
