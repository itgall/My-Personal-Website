---
/**
 * NoteLayout.astro — Digital garden note layout.
 *
 * Features:
 *   - ContentMaturity badge (seedling/budding/evergreen)
 *   - Date and updated date display
 *   - Tags
 *   - Prose content with wiki-link resolution (via remark plugin)
 *   - Bidirectional backlinks (computed at build time)
 */
import BaseLayout from "./BaseLayout.astro";
import ContentMaturity from "@components/ContentMaturity.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Backlinks from "@components/Backlinks.astro";
import SEO from "@components/SEO.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { formatDate } from "@utils/dates";
import { getBacklinksForUrl } from "@utils/backlinks";
import { features } from "@data/settings";

interface Props {
  note: CollectionEntry<"writing">;
}

const { note } = Astro.props;
const { title, date, maturity, updatedDate, description } = note.data;
const tags: string[] = note.data.tags;

/** Compute backlinks only if the feature is enabled */
const pageUrl = `/writing/${note.id}/`;
const backlinks = features.backlinks ? await getBacklinksForUrl(pageUrl) : [];

/* ── Resolve cross-references ──────────────── */
const relWritingSlugs = note.data.relatedWriting ?? [];
const relProjectSlugs = note.data.relatedProjects ?? [];

const linkedNotes = relWritingSlugs.length > 0
  ? (await getCollection("writing")).filter((n) => relWritingSlugs.includes(n.id) && n.data.published)
  : [];

const linkedProjects = relProjectSlugs.length > 0
  ? (await getCollection("projects")).filter((p) => relProjectSlugs.includes(p.id))
  : [];

const hasRelated = linkedNotes.length > 0 || linkedProjects.length > 0;
---

<BaseLayout title={title} description={description} activeNav="writing" ogImage={`/og/writing/${note.id}.png`}>
  {/* JSON-LD Article schema for research notes */}
  <SEO
    slot="head"
    pageType="note"
    title={title}
    description={description}
    url={pageUrl}
    datePublished={date.toISOString()}
    dateModified={updatedDate ? updatedDate.toISOString() : date.toISOString()}
    tags={tags}
    maturity={maturity}
  />
  <article class="prose-container pt-12" data-pagefind-body>
    <header class="mb-8">
      <Breadcrumbs items={[
        { label: "Writing", href: "/writing/" },
        { label: title }
      ]} />
      <h1 class="text-2xl font-bold tracking-tight md:text-3xl" data-pagefind-meta="title">
        {title}
      </h1>
      {/* Pagefind filter for content type */}
      <data hidden data-pagefind-filter="type:note" />
      <div class="mt-3 flex flex-wrap items-center gap-3">
        {features.contentMaturityBadges && <ContentMaturity status={maturity} />}
        <span class="font-mono text-xs text-[var(--color-muted)]">
          <time datetime={date.toISOString()}>{formatDate(date)}</time>
        </span>
        {updatedDate && (
          <span class="font-mono text-xs text-[var(--color-muted)]">
            · Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1">
          {tags.map((tag) => (
            <span class="font-mono text-[11px] text-[var(--color-muted)]">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose max-w-none">
      <slot />
    </div>

    {/* Related content */}
    {hasRelated && (
      <section class="mt-12 border-t border-[var(--color-border)] pt-8">
        <h2 class="mb-4 sc-label text-[12px] text-[var(--color-muted)]">
          Related content
        </h2>
        <div class="space-y-6">
          {linkedNotes.length > 0 && (
            <div>
              <h3 class="mb-2 text-sm font-medium text-[var(--color-text)]">Related writing</h3>
              <div class="space-y-2">
                {linkedNotes.map((n) => (
                  <a href={`/writing/${n.id}/`} class="block text-sm text-[var(--color-link)] no-underline hover:underline">
                    {n.data.title}
                  </a>
                ))}
              </div>
            </div>
          )}
          {linkedProjects.length > 0 && (
            <div>
              <h3 class="mb-2 text-sm font-medium text-[var(--color-text)]">Research projects</h3>
              <div class="space-y-2">
                {linkedProjects.map((proj) => (
                  <a href={`/projects/${proj.id}/`} class="block text-sm text-[var(--color-link)] no-underline hover:underline">
                    {proj.data.title}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    {/* Bidirectional backlinks — controlled by features.backlinks setting */}
    {features.backlinks && backlinks.length > 0 && (
      <Backlinks backlinks={backlinks.map((b) => ({ title: b.sourceTitle, url: b.sourceUrl, context: b.context }))} />
    )}
  </article>
</BaseLayout>
