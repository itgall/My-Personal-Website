---
/**
 * NewsletterSignup.astro -- Owned email capture (Buttondown).
 *
 * Reads configuration from src/data/settings.json (newsletter block) via
 * the typed accessor in src/data/settings.ts. The form posts to
 * Buttondown's embed-subscribe endpoint, which handles double opt-in and
 * unsubscribe. No API key is required or exposed; only the public
 * Buttondown username is needed.
 *
 * Safe by default: until newsletter.enabled is true AND a username is set,
 * a neutral "launching soon" state renders, so this can ship before the
 * Buttondown account exists.
 *
 * Progressive enhancement: the form is a real POST that works without
 * JavaScript (opens Buttondown's confirmation page in a new tab). With JS,
 * submission is intercepted and reported inline. The cross-origin response
 * is opaque (no-cors), so success is reported optimistically; the
 * subscriber confirms via the double opt-in email Buttondown sends.
 */
import { newsletter } from "@data/settings";

interface Props {
  heading?: string;
  description?: string;
  variant?: "inline" | "card";
}

const {
  heading = "Subscribe",
  description = "New posts by email when they go up. No spam; unsubscribe in one click.",
  variant = "card",
} = Astro.props;

const isConfigured =
  newsletter.enabled &&
  newsletter.provider === "buttondown" &&
  newsletter.buttondownUsername.length > 0;

const formAction = isConfigured
  ? `https://buttondown.com/api/emails/embed-subscribe/${newsletter.buttondownUsername}`
  : "";

const wrapClass =
  variant === "card"
    ? "rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-6"
    : "";
---

<div class={wrapClass}>
  {variant === "card" && (
    <h3 class="mb-2 text-base font-medium text-[var(--color-text)]">{heading}</h3>
  )}
  <p class="mb-4 text-sm text-[var(--color-text-secondary)] leading-relaxed">
    {description}
  </p>

  {isConfigured ? (
    <form
      class="newsletter-form"
      action={formAction}
      method="post"
      target="_blank"
      rel="noopener"
    >
      <label class="sr-only" for="newsletter-email-input">Email address</label>
      <div class="flex gap-2">
        <input
          id="newsletter-email-input"
          type="email"
          name="email"
          inputmode="email"
          autocomplete="email"
          placeholder="you@example.com"
          required
          class="flex-1 rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-2 text-sm text-[var(--color-text)] placeholder:text-[var(--color-muted)] focus:border-[var(--color-accent-border)] focus:outline-none transition-colors"
        />
        <button
          type="submit"
          class="rounded-md border border-[var(--color-accent-border)] bg-[var(--color-accent-bg)] px-4 py-2 font-mono text-[12px] font-medium text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-default"
        >
          Subscribe
        </button>
      </div>
      <input type="hidden" name="embed" value="1" />
      <div aria-hidden="true" class="absolute -left-[9999px] h-0 w-0 overflow-hidden">
        <label>Do not fill this in
          <input type="text" name="hp-url" tabindex="-1" autocomplete="off" />
        </label>
      </div>
      <p
        class="newsletter-status mt-2 text-xs text-[var(--color-muted)]"
        role="status"
        aria-live="polite"
      ></p>
    </form>
  ) : (
    <p class="text-sm text-[var(--color-muted)] italic">Newsletter launching soon.</p>
  )}
</div>

<script>
  function bindNewsletterForms() {
    const forms = document.querySelectorAll("form.newsletter-form");
    forms.forEach((form) => {
      if (form.dataset.bound === "1") return;
      form.dataset.bound = "1";
      const input = form.querySelector('input[name="email"]');
      const hp = form.querySelector('input[name="hp-url"]');
      const status = form.querySelector(".newsletter-status");
      const button = form.querySelector('button[type="submit"]');
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!input || !status || !button) return;
        if (hp && hp.value.trim() !== "") {
          status.textContent = "Thanks! Check your inbox to confirm.";
          return;
        }
        const email = input.value.trim();
        if (!email || !email.includes("@") || !email.includes(".")) {
          status.textContent = "Please enter a valid email address.";
          return;
        }
        button.disabled = true;
        const label = button.textContent;
        button.textContent = "Subscribing...";
        try {
          const body = new URLSearchParams();
          new FormData(form).forEach((value, key) => body.append(key, String(value)));
          await fetch(form.action, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body,
          });
          status.textContent = "Almost there. Check your inbox to confirm.";
          input.value = "";
        } catch (err) {
          status.textContent = "Network error. Please try again in a moment.";
        }
        button.disabled = false;
        button.textContent = label;
      });
    });
  }
  document.addEventListener("astro:page-load", bindNewsletterForms);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindNewsletterForms);
  } else {
    bindNewsletterForms();
  }
</script>
