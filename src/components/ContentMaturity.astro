---
/**
 * ContentMaturity.astro — maturity badge for digital-garden notes.
 *
 * A quiet data-voice label (small-caps, muted) with a single accent dot —
 * no emoji, no per-stage color. Carries data-pagefind-filter for faceting.
 */
import { getMaturityConfig, type MaturityLevel } from "@utils/contentMaturity";

interface Props {
  status: MaturityLevel;
}

const { status } = Astro.props;
const config = getMaturityConfig(status);
---

<span
  class="sc-label inline-flex items-center gap-1.5 text-[10px] text-[var(--color-muted)]"
  title={config.description}
  data-pagefind-filter={`maturity:${status}`}
>
  <span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
  {config.label}
</span>
