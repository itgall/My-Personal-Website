---
/**
 * NoteCard.astro — digital-garden note entry (borderless; spacing separates).
 *
 * Title, a quiet maturity label (accent dot + word, no emoji), and topic tags.
 * Hover shifts the title to the link color; nothing moves.
 */
import type { CollectionEntry } from "astro:content";
import { maturityConfig, type MaturityLevel } from "@utils/contentMaturity";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const { title, maturity, description } = note.data;
const tags: string[] = note.data.tags;
const config = maturityConfig[maturity as MaturityLevel];
---

<article
  class="note-card group py-3 transition-colors duration-200"
  data-pagefind-filter={`maturity:${maturity}`}
>
  <a href={`/notes/${note.id}/`} class="block no-underline">
    {/* Title */}
    <h3 class="text-sm font-medium leading-snug text-[var(--color-text)] transition-colors group-hover:text-[var(--color-link)]">{title}</h3>

    {/* Maturity — accent dot + label, no emoji */}
    <div class="mt-1.5 flex items-center gap-1.5">
      <span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
      <span class="font-mono text-[11px] text-[var(--color-muted)]" title={config.description}>
        {config.label}
      </span>
    </div>

    {/* Topic tags — inline text with middot separators (garden-like, informal) */}
    {tags.length > 0 && (
      <p class="mt-2.5 font-mono text-[10px] text-[var(--color-muted)] leading-relaxed">
        {tags.join(" · ")}
      </p>
    )}
  </a>
</article>
