---
/**
 * MiscGallery.astro -- the "Outside the lab" plates on the homepage.
 *
 * Gallery-plate treatment: the photograph is shown untouched (no overlay,
 * no text on the image) with a small-caps serif caption beneath it, like a
 * plate in a monograph. Labels and captions are CMS-edited via
 * src/data/homepage-gallery.json; tiles without an image fall back to a
 * quiet preset gradient swatch.
 */
import { galleryTiles } from "@data/homepage-gallery";
const items = galleryTiles;
---

<div class="plate-gallery">
  {
    items.map((item) => (
      <a class="plate" href={item.href}>
        <span
          class="plate-image"
          style={
            item.image
              ? `background-image: url('${item.image}'); background-position: ${item.focal}`
              : `background: ${item.gradient}`
          }
        />
        <span class="plate-label">{item.label}</span>
        <span class="plate-caption">{item.caption}</span>
      </a>
    ))
  }
</div>

<style>
  .plate-gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .plate {
    display: block;
    text-decoration: none;
  }

  .plate-image {
    display: block;
    aspect-ratio: 4 / 5;
    background-size: cover;
    background-position: center;
    border-radius: 2px;
  }

  .plate-label {
    display: block;
    margin-top: 0.7rem;
    font-family: var(--font-serif);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .plate-caption {
    display: block;
    margin-top: 0.15rem;
    font-family: var(--font-serif);
    font-size: 0.8125rem;
    text-align: center;
    color: var(--color-muted);
  }

  .plate:hover .plate-label {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .plate-gallery {
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  }
</style>
