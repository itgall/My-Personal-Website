---
import { galleryTiles } from "@data/homepage-gallery";
const items = galleryTiles;
---
<div class="misc-gallery">
  {items.map((item) => (
    <a class="misc-tile" href={item.href} style={item.image ? `background-image: url('${item.image}')` : item.gradient}>
      <span class="misc-inner">
        <span class="misc-title">{item.label}</span>
        <span class="misc-divider"></span>
        <span class="misc-cta">{item.caption} →</span>
      </span>
    </a>
  ))}
</div>
<style>
  .misc-gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.875rem; }
  .misc-tile { position: relative; aspect-ratio: 1 / 1; border-radius: 12px; overflow: hidden; text-decoration: none; background-size: cover; background-position: center; box-shadow: 0 1px 6px rgba(0,0,0,0.08); transition: transform 0.22s ease, box-shadow 0.22s ease; }
  .misc-tile::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.5), rgba(0,0,0,0.08)); z-index: 1; }
  .misc-tile:hover { transform: translateY(-6px); box-shadow: 0 12px 26px rgba(0,0,0,0.18); }
  .misc-inner { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; text-align: center; padding: 0.75rem; }
  .misc-title { font-family: var(--font-serif, Georgia, serif); font-size: 1.1875rem; line-height: 1.1; letter-spacing: 0.01em; }
  .misc-divider { width: 42px; height: 1px; background: rgba(255,255,255,0.65); margin: 0.625rem 0; transition: width 0.22s ease; }
  .misc-tile:hover .misc-divider { width: 68px; }
  .misc-cta { font-size: 0.6875rem; opacity: 0.9; letter-spacing: 0.02em; }
  @media (max-width: 640px) { .misc-gallery { grid-template-columns: 1fr 1fr; } }
  @media (prefers-reduced-motion: reduce) { .misc-tile { transition: none; } .misc-tile:hover { transform: none; } .misc-tile:hover .misc-divider { width: 42px; } }
</style>
