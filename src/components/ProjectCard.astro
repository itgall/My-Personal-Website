---
import type { CollectionEntry } from "astro:content";
interface Props {
  project: CollectionEntry<"projects">;
}
const { project } = Astro.props;
const { title, description, institution, heroImage, heroCaption, highlightTag } = project.data;
const tags: string[] = project.data.tags;
const year = project.data.date.getFullYear();
const topic = highlightTag ?? (tags.length > 0 ? tags[0] : null);
---

<article class="project-card group">
  <a href={`/projects/${project.id}/`} class="card-link">
    <div class="card-figure">
      {
        heroImage ? (
          <img src={heroImage} alt={heroCaption || title} loading="lazy" decoding="async" />
        ) : (
          <span class="figure-placeholder font-mono">{topic ?? "research"}</span>
        )
      }
    </div>
    <div class="card-body">
      <div class="card-meta">
        <span class="card-venue">{institution.split(",")[0]} &middot; {year}</span>
        {topic && <span class="card-topic">{topic}</span>}
      </div>
      <h3 class="card-title">{title}</h3>
      {description && <p class="card-description">{description}</p>}
    </div>
  </a>
</article>

<style>
  .project-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    height: 100%;
    overflow: hidden;
  }
  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
  }
  .card-figure {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .figure-placeholder {
    font-size: 0.625rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .card-body {
    padding: 0.75rem 0.875rem 0.875rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }
  .card-venue {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-muted);
  }
  /* Topic is metadata, not an accent event — the page's one green object is
     the figure caption's link (VISUAL-DIRECTION §Color). */
  .card-topic {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-muted);
    white-space: nowrap;
  }
  .card-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.3;
    transition: color 0.15s ease;
  }
  .project-card:hover .card-title {
    color: var(--color-accent);
  }
  .card-description {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-top: 0.375rem;
  }
</style>
