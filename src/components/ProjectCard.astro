---
import type { CollectionEntry } from "astro:content";
interface Props { project: CollectionEntry<"projects">; }
const { project } = Astro.props;
const { title, description, institution, heroImage, heroCaption, highlightTag, featured } = project.data;
const tags: string[] = project.data.tags;
const year = project.data.date.getFullYear();
const topic = highlightTag ?? (tags.length > 0 ? tags[0] : null);
---
<article class:list={["project-card group", { "is-featured": featured }]}>
  {featured && (
    <span class="pin" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36">
        <path fill="#BE1931" d="M23.651 23.297 12.702 12.348l9.386-7.821 9.385 9.385z"></path>
        <path fill="#DD2E44" d="M34.6 13.912a4.42 4.42 0 0 1-6.255 0l-6.257-6.256a4.426 4.426 0 0 1 6.257-6.258L34.6 7.656a4.423 4.423 0 0 1 0 6.256z"></path>
        <path fill="#99AAB5" d="M14 17.823S-.593 35.029.188 35.813C.97 36.596 18.177 22 18.177 22L14 17.823z"></path>
        <path fill="#DD2E44" d="M25.215 27.991a4.423 4.423 0 0 1-6.258 0L8.009 17.041a4.425 4.425 0 0 1 6.258-6.256l10.948 10.949a4.424 4.424 0 0 1 0 6.257z"></path>
      </svg>
    </span>
  )}
  <a href={`/projects/${project.id}/`} class="card-link">
    <div class="card-figure">
      {heroImage ? (
        <img src={heroImage} alt={heroCaption || title} loading="lazy" decoding="async" />
      ) : (
        <span class="figure-placeholder font-mono">{topic ?? "research"}</span>
      )}
    </div>
    <div class="card-body">
      <div class="card-meta">
        <span class="card-venue">{institution.split(",")[0]} · {year}</span>
        {topic && <span class="card-topic">{topic}</span>}
      </div>
      <h3 class="card-title">{title}</h3>
      {description && <p class="card-description">{description}</p>}
      {tags.length > 0 && (
        <div class="card-tags">
          {tags.slice(0, 3).map((tag) => (<span class="card-tag">{tag}</span>))}
        </div>
      )}
    </div>
  </a>
</article>
<style>
  .project-card { position: relative; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 10px; height: 100%; overflow: visible; }
  .pin { position: absolute; top: -12px; left: 14px; width: 26px; height: 26px; z-index: 3; transform: rotate(-12deg); filter: drop-shadow(0 2px 3px rgba(0,0,0,0.28)); pointer-events: none; }
  .pin svg { width: 100%; height: 100%; display: block; }
  .card-link { display: flex; flex-direction: column; height: 100%; text-decoration: none; }
  .card-figure { width: 100%; aspect-ratio: 16 / 10; border-radius: 9px 9px 0 0; overflow: hidden; background: linear-gradient(135deg, var(--color-surface), var(--color-border)); display: flex; align-items: center; justify-content: center; }
  .card-figure img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s ease; }
  .figure-placeholder { font-size: 0.625rem; color: var(--color-muted); letter-spacing: 0.04em; text-transform: lowercase; }
  .card-body { padding: 0.75rem 0.875rem 0.875rem; display: flex; flex-direction: column; flex: 1; }
  .card-meta { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.375rem; }
  .card-venue { font-family: var(--font-mono); font-size: 0.625rem; color: var(--color-muted); }
  .card-topic { font-family: var(--font-mono); font-size: 0.5625rem; color: var(--color-accent); display: inline-flex; align-items: center; gap: 0.25rem; white-space: nowrap; }
  .card-topic::before { content: ""; width: 5px; height: 5px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; }
  .card-title { font-size: 0.875rem; font-weight: 600; color: var(--color-ink); line-height: 1.3; transition: color 0.15s ease; }
  .project-card:hover .card-title { color: var(--color-accent); }
  .project-card:hover .card-figure img { transform: scale(1.04); }
  .card-description { font-size: 0.75rem; color: var(--color-text-secondary); line-height: 1.5; margin-top: 0.375rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: auto; padding-top: 0.75rem; }
  .card-tag { display: inline-flex; align-items: center; font-family: var(--font-mono); font-size: 0.625rem; padding: 0.15em 0.5em; border-radius: 9999px; background: var(--color-accent-bg); color: var(--color-accent); border: 1px solid var(--color-border); letter-spacing: 0.02em; }
  @media (prefers-reduced-motion: reduce) { .project-card, .card-title, .card-figure img { transition: none; } .project-card:hover .card-figure img { transform: none; } }
</style>
