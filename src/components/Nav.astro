---
/**
 * Nav.astro — Primary navigation bar (three-tier architecture).
 *
 * Tier 1: Primary nav (7 items) — horizontal links
 * Tier 2: "More" dropdown — CSS-only hover/focus-within (zero JavaScript)
 * Tier 3: Contact CTA button — styled distinctly from nav items
 *
 * The More dropdown uses CSS :hover and :focus-within to show/hide.
 * This is the same mechanism used by GitHub, Stripe, and most modern
 * nav menus. No JavaScript, no <details>, no event listeners.
 *
 * Mobile hamburger still uses <details>/<summary> (proven working).
 */
import { primaryNav, moreNav } from "@data/navigation";
import { siteMetadata } from "@data/meta";
import { features, sections } from "@data/settings";

interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;
const currentPath = Astro.url.pathname;

const sectionPaths: Record<string, keyof typeof sections> = {
  "/publications/": "publications",
  "/projects/": "projects",
  "/blog/": "blog",
  "/notes/": "notes",
  "/teaching/": "teaching",
  "/cv/": "cv",
  "/about/": "about",
  "/contact/": "contact",
  "/ventures/": "ventures",
  "/speaking/": "speaking",
  "/podcast/": "podcast",
};

const filteredPrimary = primaryNav.filter((item) => {
  const section = sectionPaths[item.href];
  if (section && !sections[section]) return false;
  return true;
});

const filteredMore = moreNav.filter((item) => {
  const section = sectionPaths[item.href];
  if (section && !sections[section]) return false;
  return true;
});

function isActive(item: (typeof primaryNav)[number]): boolean {
  if (item.activeMatch) {
    return new RegExp(item.activeMatch).test(currentPath);
  }
  if (item.href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(item.href);
}

const moreIsActive = filteredMore.some((item) => isActive(item));
---

<nav
  class="vt-nav sticky top-0 z-50 glass border-b border-[var(--color-border)] transition-[border-color] duration-200"
  aria-label="Main navigation"
  data-pagefind-ignore
>
  <div class="full-container flex h-14 items-center">
    {/* Site name */}
    <a
      href="/"
      class="vt-site-title shrink-0 text-sm font-semibold tracking-tight text-[var(--color-text)] hover:text-[var(--color-text)] no-underline"
    >
      {siteMetadata.name}
    </a>

    {/* ── Desktop nav ─────────────────────────────────────────────── */}
    <div id="desktop-nav" class="ml-auto hidden items-center gap-1 md:flex">
      <ul class="flex items-center gap-1" role="list">
        {filteredPrimary.map((item) => (
          <li class="nav-item">
            <a
              href={item.href}
              class:list={[
                "inline-flex items-center px-2.5 py-1.5 text-[13px] rounded-md transition-colors duration-150 no-underline",
                isActive(item)
                  ? "text-[var(--color-text)] font-medium bg-[var(--color-accent-bg)]"
                  : "text-[var(--color-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-raised)]",
              ]}
              aria-current={isActive(item) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* ── Mobile hamburger menu ───────────────────────────────────── */}
    <div class="ml-auto flex items-center gap-2 md:hidden">
      <details class="mobile-nav relative">
        <summary
          class="flex h-8 w-8 cursor-pointer items-center justify-center rounded-md border border-[var(--color-border)] text-[var(--color-muted)] transition-colors hover:text-[var(--color-text)] list-none [&::-webkit-details-marker]:hidden"
          aria-label="Toggle navigation menu"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </summary>
        <div
          class="fixed inset-x-0 top-14 bottom-0 z-50 bg-[var(--color-bg)] border-t border-[var(--color-border)] p-6 overflow-y-auto"
          role="menu"
        >
          <ul class="flex flex-col gap-0.5" role="list">
            {filteredPrimary.map((item) => (
              <li role="none">
                <a
                  href={item.href}
                  role="menuitem"
                  class:list={[
                    "flex items-center rounded-md px-3 py-3 text-base font-medium transition-colors no-underline",
                    isActive(item)
                      ? "text-[var(--color-accent)] bg-[var(--color-accent-bg)]"
                      : "text-[var(--color-text)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent-bg)]",
                  ]}
                  aria-current={isActive(item) ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
          {filteredMore.length > 0 && (
            <div class="mt-3 pt-3 border-t border-[var(--color-border)]">
              <p class="px-3 pb-1 font-mono text-[10px] tracking-wider text-[var(--color-muted)] uppercase">More</p>
              <ul class="flex flex-col gap-0.5" role="list">
                {filteredMore.map((item) => (
                  <li role="none">
                    <a
                      href={item.href}
                      role="menuitem"
                      class:list={[
                        "flex items-center rounded-md px-3 py-3 text-base font-medium transition-colors no-underline",
                        isActive(item)
                          ? "text-[var(--color-accent)] bg-[var(--color-accent-bg)]"
                          : "text-[var(--color-text)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent-bg)]",
                      ]}
                      aria-current={isActive(item) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </details>
    </div>
  </div>
</nav>

{/* Close mobile menu on View Transition navigation */}
<script is:inline>
  if(!window._mobileMenuCloseInit){
    window._mobileMenuCloseInit=true;
    document.addEventListener("astro:before-preparation", function(){
      var d=document.querySelector("details.mobile-nav");
      if(d) d.removeAttribute("open");
    });
  }
</script>


