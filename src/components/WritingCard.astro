---
/**
 * WritingCard.astro — list row for a writing entry (borderless; spacing separates).
 *
 * Mono meta row (kind, reading time on essays, date), serif title, two-line
 * description. Hover shifts the title to the link color; nothing moves.
 */
import type { CollectionEntry } from "astro:content";
import { formatDate } from "@utils/dates";
import { calculateReadingTime } from "@utils/readingTime";

interface Props {
  entry: CollectionEntry<"writing">;
  /** Whether to render tag links below the description (default: true) */
  showTags?: boolean;
}

const { entry, showTags = true } = Astro.props;
const { title, kind, date, description, readingTime } = entry.data;
const tags: string[] = entry.data.tags;

const kindLabels: Record<string, string> = {
  essay: "Essay",
  note: "Note",
};

/* Reading time is an essay affordance; a one-minute estimate on every short
   note would be noise. */
const displayReadingTime =
  kind === "essay" ? (readingTime ?? calculateReadingTime(entry.body ?? "")) : null;
---

<article class="writing-card py-4 transition-colors duration-200">
  <a href={`/writing/${entry.id}/`} class="group block no-underline">
    <div class="flex items-center gap-2 text-xs">
      <span class="font-mono text-[11px] text-[var(--color-muted)]">{kindLabels[kind]}</span>
      {displayReadingTime && (
        <span class="font-mono text-[11px] text-[var(--color-muted)]">{displayReadingTime}</span>
      )}
      <span class="ml-auto font-mono text-[11px] text-[var(--color-muted)]">{formatDate(date)}</span>
    </div>

    <h3 class="mt-2 text-[15px] font-medium leading-snug text-[var(--color-text)] group-hover:text-[var(--color-link)] transition-colors">{title}</h3>

    {description && (
      <p class="mt-1.5 text-sm leading-relaxed text-[var(--color-muted)] line-clamp-2">
        {description}
      </p>
    )}
  </a>

  {showTags && tags.length > 0 && (
    <div class="mt-2.5 flex flex-wrap gap-x-3 gap-y-1">
      {tags.map((tag) => (
        <a
          href={`/writing/tags/${tag}/`}
          class="font-mono text-[11px] text-[var(--color-muted)] no-underline hover:text-[var(--color-accent)] transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>
  )}
</article>
