---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

type MiscEntry = CollectionEntry<"misc">;

const SECTION_LABELS: Record<string, string> = {
  travel: "Travel", caving: "Caving", languages: "Languages", reading: "Reading",
};

export async function getStaticPaths() {
  const entries: MiscEntry[] = await getCollection("misc", ({ data }: MiscEntry) => data.published);
  return entries.map((entry: MiscEntry) => ({ params: { entry: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: MiscEntry };
const { Content } = await render(entry);
const { title, section, location, heroImage, heroCaption, heroFocal } = entry.data;
const dateStr = entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long" });
const sectionLabel = SECTION_LABELS[section] ?? "Misc";
const metaParts = [location, dateStr].filter(Boolean);
---

<BaseLayout title={title} description={entry.data.summary || `${title} — ${sectionLabel}`} activeNav="misc">
  <article class="wide-container py-16">
    <a href={`/misc/#${section}`} class="misc-back">&larr; {sectionLabel}</a>
    <header class="misc-detail-header">
      <h1 class="vt-page-title text-3xl font-bold tracking-tight md:text-4xl leading-tight">{title}</h1>
      {metaParts.length > 0 && (<p class="misc-detail-meta">{metaParts.join(" · ")}</p>)}
    </header>
    {heroImage && (
      <figure class="misc-hero">
        <img src={heroImage} alt={heroCaption || title} loading="eager" decoding="async" style={`object-position: ${heroFocal}`} />
        {heroCaption && <figcaption>{heroCaption}</figcaption>}
      </figure>
    )}
    <div class="prose"><Content /></div>
  </article>
</BaseLayout>

<style>
  .misc-back { display: inline-block; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.03em; color: var(--color-muted); text-decoration: none; margin-bottom: 1.5rem; transition: color 0.15s ease; }
  .misc-back:hover { color: var(--color-accent); }
  .misc-detail-header { margin-bottom: 1.75rem; }
  .misc-detail-meta { font-family: var(--font-mono); font-size: 0.8125rem; color: var(--color-muted); margin-top: 0.625rem; }
  .misc-hero { margin: 0 0 2rem; }
  .misc-hero img { width: 100%; border-radius: 12px; display: block; }
  .misc-hero figcaption { font-size: 0.8125rem; color: var(--color-muted); margin-top: 0.625rem; text-align: center; }
</style>
