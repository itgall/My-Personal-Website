<script is:inline>
/*
 * TOC active-section highlighting via IntersectionObserver.
 * Matches the behavior of the essay-page TOC for consistency.
 * Only activates when the sidebar is visible (≥72rem / 1152px).
 */
(function() {
  if (window.innerWidth < 1152) return;

  var links = document.querySelectorAll(".cv-toc-link[data-toc-slug]");
  if (!links.length) return;

  var sections = [];
  links.forEach(function(link) {
    var slug = link.dataset.tocSlug;
    var el = document.getElementById(slug);
    if (el) sections.push({ el: el, link: link });
  });

  if (!sections.length) return;

  var currentActive = null;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        if (currentActive) currentActive.classList.remove("active");
        var match = sections.find(function(s) { return s.el === entry.target; });
        if (match) {
          match.link.classList.add("active");
          currentActive = match.link;
        }
      }
    });
  }, {
    rootMargin: "-80px 0px -70% 0px",
    threshold: 0,
  });

  sections.forEach(function(s) { observer.observe(s.el); });
})();
</script>
