  /*
   * ═══════════════════════════════════════════════════════════════════
   * PRINT STYLES — Single-source PDF generation from HTML
   * ═══════════════════════════════════════════════════════════════════
   *
   * When the user clicks "Save as PDF" (which calls window.print()), or
   * invokes the browser's print function directly, these rules produce
   * a properly formatted print/PDF output from the same HTML source.
   *
   * Strategy:
   *   1. Hide everything that is not CV content (nav, footer, sidebar,
   *      theme toggle, any [data-print-hidden] elements)
   *   2. Reset the layout to a single column with proper page margins
   *   3. Scale typography to print-friendly sizes (points, not rems)
   *   4. Use page-break controls to keep entries together where possible
   *   5. Convert colored text to high-contrast near-black for legibility
   *   6. Strip hyperlink underlines (URLs remain as text)
   */
  @media print {
    /* Page setup: US Letter with 0.5" side margins, 0.65" top/bottom */
    @page {
      size: letter;
      margin: 0.65in 0.55in;
    }

    /* Hide all navigation, footer, sidebar, and explicitly marked elements */
    :global(nav),
    :global(footer),
    :global(.mobile-nav),
    :global([data-print-hidden]),
    .cv-sidebar,
    .cv-header-actions {
      display: none !important;
    }

    /* Reset page background and colors for print */
    :global(body),
    :global(html) {
      background: white !important;
      color: black !important;
      font-size: 10pt;
      line-height: 1.4;
    }

    /* Reset grid layout to single column, remove width constraints */
    .cv-article {
