---
/**
 * index.astro — Homepage (content-forward layout).
 *
 * Design philosophy: engineer-like restraint. Modeled after Geoffrey Litt,
 * Andrej Karpathy, and Patrick Collison — content is the feature, decoration
 * is limited to horizontal rules and blue links.
 *
 * Structure:
 *   1. Hero: headshot + name + subtitle + intro paragraph + links
 *   2. Selected Work: project list with descriptions
 *   3. Recent Writing: date-aligned list
 *   4. Research Interests: prose paragraph
 *
 * Content-structure separation: this file contains ONLY rendering logic.
 * All content lives in content collections (projects, posts, podcast)
 * and data files (bibliography.bib, cv.yaml). A complete visual redesign
 * of this page touches zero content files.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import MiscGallery from "@components/MiscGallery.astro";
import { siteMetadata } from "@data/meta";
import { profileImage, profileFocal } from "@data/homepage";
import { getCollection, type CollectionEntry } from "astro:content";

type Post = CollectionEntry<"posts">;
type Project = CollectionEntry<"projects">;

const recentPosts: Post[] = (await getCollection("posts", ({ data }: Post) => data.published))
  .sort((a: Post, b: Post) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const projects: Project[] = (await getCollection("projects", ({ data }: Project) => data.published))
  .sort((a: Project, b: Project) => a.data.number.localeCompare(b.data.number));

function formatShortDate(d: Date): string {
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

const categoryLabels: Record<string, string> = {
  technical: "Technical note",
  thesis: "Thesis",
  essay: "Essay",
  dispatch: "Dispatch",
  "build-log": "Build log",
};
---

<BaseLayout activeNav="home" pageType="home" ogImage="/og/index.png">
  <div class="wide-container py-16 md:py-24">

    {/* ─── Hero ─────────────────────────────────────────────────── */}
    <section class="hero-section mb-16">
      {/* Social icons — top right */}
      <div class="flex justify-center md:justify-end mb-5">
        <nav class="social-row" aria-label="Profile links">
          <a href="mailto:itgall@mit.edu" class="social-icon" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg>
          </a>
          <a href="https://linkedin.com/in/isaactgallegos" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 17V9.93H6V17h2.34zM7.17 8.9a1.36 1.36 0 1 0 0-2.71 1.36 1.36 0 0 0 0 2.71zM18 17v-3.87c0-2.06-1.1-3.02-2.57-3.02-1.19 0-1.72.65-2.02 1.11V9.93h-2.34c.03.66 0 7.07 0 7.07h2.34v-3.95c0-.21.02-.42.08-.57.16-.42.55-.86 1.19-.86.84 0 1.18.64 1.18 1.58V17H18z"></path></svg>
          </a>
          <a href="https://github.com/itgall" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02.8-.22 1.65-.33 2.5-.33.85 0 1.7.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10.01 10.01 0 0 0 22 12c0-5.52-4.48-10-10-10z"></path></svg>
          </a>
          <a href="https://orcid.org/0009-0007-9290-6289" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="ORCID">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zM7.37 18.4H5.62V7.6h1.75v10.8zM6.5 6.4a1.02 1.02 0 1 1 0-2.04 1.02 1.02 0 0 1 0 2.04zm12 12h-1.74v-5.27c0-1.26-.02-2.88-1.75-2.88-1.76 0-2.03 1.37-2.03 2.79v5.36H11.2V7.6h1.67v1.48h.02c.23-.44.8-.9 1.65-.9 1.77 0 2.96 1.16 2.96 3.66v6.56z"></path></svg>
          </a>
          <a href="https://scholar.google.com/citations?user=gr1ZNUAAAAAJ&hl=en" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Google Scholar">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.84 3.77A8 8 0 0 1 12 8a8 8 0 0 1 7.16 5.27L24 9.5z"></path></svg>
          </a>
        </nav>
      </div>

      {/* Photo + intro */}
      <div class="flex flex-col items-center gap-7 text-center md:flex-row md:items-start md:gap-8 md:text-left">
        <img
          src={profileImage}
          alt="Isaac Gallegos"
          loading="eager"
          decoding="async"
          width="260"
          height="325"
          class="hero-photo shrink-0"
          style={`object-position: ${profileFocal}`}
        />
        <div class="min-w-0">
          <h1 class="vt-page-title text-3xl font-semibold tracking-tight leading-tight md:text-4xl">
            {siteMetadata.name}
          </h1>
          <p class="mt-2 text-base text-[var(--color-text-secondary)]">
            Research Engineer · Harvard Medical School
          </p>

          <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">
            I build optical systems and inverse models at the Wellman Center for
            Photomedicine (Harvard Medical School). Most of my time goes into
            interferometric imaging, spectral unmixing, and figuring out what you
            can recover from broadband optical measurements. Lately I've been
            spending more and more time on quantum photonics, integrated photonic
            devices, and machine learning for optical design. Applying to PhD
            programs for Fall 2027. Outside the lab, I travel when I can and go
            caving.
          </p>

          <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed">
            Currently: finishing a laser safety calculator for tissue exposure limits,
            and reading about topology and differential geometry.
          </p>

          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm md:justify-start">
            <a href="/documents/gallegos-cv.pdf" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">Curriculum Vitae →</a>
            <a href="mailto:itgall@mit.edu" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">itgall@mit.edu</a>
          </div>
        </div>
      </div>
    </section>

    <style>
      .social-row { display: flex; gap: 1rem; }
      .social-icon { width: 24px; height: 24px; color: var(--color-muted); transition: color 0.15s ease, transform 0.15s ease; display: inline-flex; align-items: center; justify-content: center; }
      .social-icon svg { width: 21px; height: 21px; display: block; }
      .social-icon:hover { color: var(--color-accent); transform: translateY(-1px); }
      .hero-photo { width: 260px; height: 325px; object-fit: cover; border-radius: 12px; }
      @media (max-width: 767px) { .hero-photo { width: 200px; height: 250px; } }
      @media (prefers-reduced-motion: reduce) { .social-icon { transition: color 0.15s ease; } .social-icon:hover { transform: none; } }
    </style>

    {/* ─── Selected Work ────────────────────────────────────────── */}
    <section class="py-14">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-xl font-semibold tracking-tight">Selected work</h2>
        <a href="/projects/" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">All projects &rarr;</a>
      </div>
      {projects.length > 0 ? (
        <div class="space-y-6">
          {projects.map((project) => (
            <a
              href={`/projects/${project.id}/`}
              class="group block no-underline"
            >
              <span class="text-[15px] font-medium text-[var(--color-text)] group-hover:text-[var(--color-link)] transition-colors">
                {project.data.title}
              </span>
              <p class="mt-1 text-sm text-[var(--color-text-secondary)] leading-relaxed line-clamp-2">
                {project.data.description}
              </p>
              <span class="mt-1 text-xs text-[var(--color-muted)]">{project.data.institution}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--color-muted)] italic">No projects published yet.</p>
      )}
    </section>

    {/* ─── Recent Writing ───────────────────────────────────────── */}
    {recentPosts.length > 0 && (
      <section class="py-14">
          <div class="flex items-baseline justify-between mb-8">
            <h2 class="text-xl font-semibold tracking-tight">Recent writing</h2>
            <a href="/blog/" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">All writing &rarr;</a>
          </div>
          <div class="space-y-4">
            {recentPosts.map((post) => {
              const cat = categoryLabels[post.data.category] ?? post.data.category;
              return (
                <a
                  href={`/blog/${post.id}/`}
                  class="group flex items-baseline gap-4 no-underline"
                >
                  <span class="font-mono text-xs text-[var(--color-muted)] shrink-0 w-20">
                    {formatShortDate(post.data.date)}
                  </span>
                  <span class="flex-1 min-w-0 text-[15px] font-medium text-[var(--color-text)] group-hover:text-[var(--color-link)] transition-colors">
                    {post.data.title}
                  </span>
                  <span class="shrink-0 text-xs text-[var(--color-muted)] hidden sm:inline">
                    {cat}
                  </span>
                </a>
              );
            })}
          </div>
        </section>
    )}

    {/* ─── Research Interests ───────────────────────────────────── */}
    <section class="py-14">
      <div class="max-w-2xl mx-auto md:mx-0">
        <h2 class="text-xl font-semibold tracking-tight mb-4">Research interests</h2>
        <p class="text-[var(--color-text-secondary)] leading-relaxed">
          I'm interested in what happens when you shrink an optical table onto a
          chip and let a neural network design it. More specifically: quantum
          photonics, spin-photon interfaces, inverse design for nanophotonic
          devices, and using machine learning to model optical systems that are
          too complex to simulate from first principles. I also care about
          single-photon detection, nonlinear optics, and laser physics, which is
          where I started.
        </p>
        <a href="/publications/" class="inline-block mt-4 text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">
          View publications &rarr;
        </a>
      </div>
    </section>

    <section class="py-14">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-xl font-semibold tracking-tight">Outside the lab</h2>
        <a href="/misc/" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">More &rarr;</a>
      </div>
      <MiscGallery />
    </section>
  </div>
</BaseLayout>
