---
/**
 * 404.astro -- Not found page.
 *
 * Warm, minimal design with a subtle optics reference. Maintains the full
 * site shell (nav, footer, typography, palette) and provides a clear path
 * back to the homepage. The message is editable in the CMS under
 * Pages -> 404 Page (src/data/not-found.json).
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import { message } from "@data/not-found";
---

<BaseLayout title="Page Not Found">
  <div class="prose-container flex min-h-[55vh] flex-col items-center justify-center text-center">
    <h1 class="text-6xl font-bold tracking-tight">404</h1>

    <p class="mt-4 max-w-sm text-base leading-relaxed text-[var(--color-muted)]">
      {message}
    </p>

    <div class="mt-8">
      <a
        href="/"
        class="text-sm font-medium text-[var(--color-link)] no-underline transition-colors hover:text-[var(--color-link-hover)]"
      >
        &larr; Back to the homepage
      </a>
    </div>
  </div>
</BaseLayout>
