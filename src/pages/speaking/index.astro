---
/**
 * speaking/index.astro — Speaking & Media listing.
 *
 * Bridges academic and public spheres. Essential for KHS
 * "purposeful leadership" criterion. Signals ability to
 * communicate complex ideas to broad audiences.
 *
 * Uses wide-container (960px) for structured data layout.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type Talk = CollectionEntry<"speaking">;

const allTalks: Talk[] = (await getCollection("speaking", ({ data }: Talk) => data.published))
  .sort((a: Talk, b: Talk) => b.data.date.getTime() - a.data.date.getTime());

const featured = allTalks.filter((t) => t.data.featured);
const regular = allTalks.filter((t) => !t.data.featured);

const typeLabels: Record<string, string> = {
  "talk": "Talk",
  "panel": "Panel",
  "keynote": "Keynote",
  "guest-lecture": "Guest Lecture",
  "podcast": "Podcast",
  "media": "Media",
};

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short" });
}
---

<BaseLayout title="Speaking & Media" activeNav="speaking">
  <div class="wide-container py-16">
    <header class="mb-12 border-b border-[var(--color-border)] pb-8">
      <h1 class="vt-page-title text-3xl font-bold tracking-tight md:text-4xl leading-tight">
        Speaking & Media
      </h1>
      <p class="mt-3 text-base text-[var(--color-muted)] leading-relaxed max-w-2xl">
        Talks, panels, and media appearances on photonics, quantum systems, and deep-tech entrepreneurship.
      </p>
    </header>

    {allTalks.length === 0 ? (
      <div class="py-12">
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed max-w-lg">
          Talks, panels, and invited presentations will appear here as they are scheduled.
          For inquiries about speaking engagements, please <a href="/contact/" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">get in touch</a>.
        </p>
      </div>
    ) : (
      <div>
        {/* Featured talks with video */}
        {featured.length > 0 && (
          <section class="mb-14">
            <h2 class="mb-6 text-base font-medium text-[var(--color-text)]">Featured</h2>
            <div class="space-y-6">
              {featured.map((talk) => (
                <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
                  {talk.data.videoUrl && (
                    <div class="mb-4 aspect-video rounded-md overflow-hidden bg-[var(--color-bg-off)]">
                      <iframe
                        src={talk.data.videoUrl}
                        class="w-full h-full"
                        allowfullscreen
                        loading="lazy"
                        title={talk.data.title}
                      ></iframe>
                    </div>
                  )}
                  <div class="flex items-center gap-2 mb-2">
                    <span class="font-mono text-[10px] tracking-wider text-[var(--color-accent)]">
                      {typeLabels[talk.data.type] || "Talk"}
                    </span>
                    <span class="text-[var(--color-border)]">·</span>
                    <span class="font-mono text-[11px] text-[var(--color-muted)]">
                      {formatDate(talk.data.date)}
                    </span>
                  </div>
                  <h3 class="text-base font-medium text-[var(--color-text)] mb-1">{talk.data.title}</h3>
                  <p class="text-sm text-[var(--color-muted)]">{talk.data.event}</p>
                  {talk.data.description && (
                    <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">{talk.data.description}</p>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        {/* All talks — chronological list */}
        {regular.length > 0 && (
          <section>
            <h2 class="mb-6 text-base font-medium text-[var(--color-text)]">All engagements</h2>
            <div class="space-y-1">
              {regular.map((talk) => (
                <div class="flex items-baseline gap-4 py-3 border-b border-[var(--color-border-subtle)]">
                  <span class="font-mono text-[11px] text-[var(--color-muted)] w-20 shrink-0">
                    {formatDate(talk.data.date)}
                  </span>
                  <div class="flex-1 min-w-0">
                    <span class="text-sm font-medium text-[var(--color-text)]">{talk.data.title}</span>
                    <span class="text-sm text-[var(--color-muted)]"> — {talk.data.event}</span>
                  </div>
                  <span class="font-mono text-[10px] text-[var(--color-muted)] shrink-0">
                    {typeLabels[talk.data.type] || "Talk"}
                  </span>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>
    )}

    {/* Topics I speak about */}
    <section class="mt-14 pt-8 border-t border-[var(--color-border)]">
      <h2 class="mb-4 text-base font-medium text-[var(--color-text)]">Topics I speak about</h2>
      <div class="flex flex-wrap gap-2">
        {["Spectroscopic OCT", "Photoacoustic Imaging", "Quantum Sensing", "Deep-Tech Entrepreneurship", "Physics-to-Product Translation", "Computational Inverse Problems"].map((topic) => (
          <span class="rounded border border-[var(--color-border)] px-2.5 py-1 font-mono text-[10px] text-[var(--color-muted)]">
            {topic}
          </span>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
