---
/**
 * about.astro — About page (Pattern 1: hero + chronological timeline).
 *
 * Architecture:
 *   Full-width alternating background sections with constrained content width.
 *   Each <section> spans the full viewport; the inner <.about-inner> constrains
 *   content to 760px. This eliminates the "narrow column floating in empty space"
 *   problem on wide screens while keeping reading line length optimal.
 *
 * Structure:
 *   1. Hero — photo, identity, tagline, affiliations, social links
 *   2. Bio — one concise paragraph of current work (replaces the essay)
 *   3. Trajectory — reverse-chronological career timeline with institutional detail
 *   4. Learn more — compact CV / publications / research links row
 *
 * This replaces the previous ~320-line essay-style About page which contained
 * a "Research focus" section, a "Why it matters" section with two long
 * paragraphs, a "Path" narrative, a "Research direction" callout, a
 * "Research interests" grid, a "Leadership & community" section with four
 * sub-sections, a "Trajectory" timeline, and an "Awards" section.
 */
import BaseLayout from "@layouts/BaseLayout.astro";

interface TimelineEntry {
  period: string;
  role: string;
  institution: string;
  description?: string;
  current?: boolean;
  future?: boolean;
}

const timeline: TimelineEntry[] = [
  {
    period: "2027 (target)",
    role: "PhD program",
    institution: "Physics, Fall 2027 (applying)",
    description:
      "Pursuing a physics PhD in quantum information and quantum networks: photonic interconnects and entanglement distribution between spin-based quantum nodes.",
    future: true,
  },
  {
    period: "2025 — present",
    role: "Research Engineer",
    institution: "Wellman Center for Photomedicine · Harvard Medical School · MGH",
    description:
      "I build swept-source interferometric systems, write inverse models for spectral measurements, and prototype broadband micro-LED imaging hardware. First-author manuscript in preparation.",
  },
  {
    period: "2023 — 2024",
    role: "Research Assistant & Project Lead",
    institution: "Colorado School of Mines — Physics Department & Ultrafast Laser Lab",
    description:
      "Computed Fisher information metrics for Ising models to test holographic duality conjectures. Also led a five-person team designing supersonic gas nozzles for high harmonic generation.",
  },
  {
    period: "2021 — 2024",
    role: "B.S. Engineering Physics",
    institution: "Colorado School of Mines · 3.99 GPA",
    description:
      "Three years of quantum optics, laser physics, and electronics. Built solid-state lasers (Pr:YLF and Nd:YAG), measured Bell inequality violations with entangled photons, and designed a gated photon-counting circuit on an FPGA.",
  },
];
---

<BaseLayout title="About" activeNav="about" description="Isaac Gallegos builds interferometric imaging systems and spectral inverse models at the Wellman Center for Photomedicine. Applying to PhD programs for Fall 2027.">

  {/* ═══════ HERO: identity, tagline, affiliations, links ═══════════ */}
  <section class="about-section">
    <div class="about-inner">

      <div class="max-w-2xl">
        <h1 class="vt-page-title font-mono text-[11px] font-medium uppercase tracking-wider text-[var(--color-muted)]">
          About
        </h1>

        <p class="mt-4 italic text-[22px] leading-[1.5] text-[var(--color-text-secondary)] md:text-[24px]">
          I build optical systems. Lately I've been learning to build quantum ones too.
        </p>
      </div>

    </div>
  </section>

  {/* ═══════ BIO: one concise paragraph ═════════════════════════════ */}
  <section class="about-section about-section-alt">
    <div class="about-inner">

      <p class="text-[16px] leading-[1.78] text-[var(--color-text-secondary)]">
        I work at the Wellman Center for Photomedicine, where I build swept-source
        interferometric systems and write inverse models that try to figure out what
        a sample is made of from how it scatters light. I've also built spectral
        unmixing pipelines for photoacoustic data and prototyped a broadband imaging
        system that uses individually addressable micro-LEDs instead of a swept laser.
        Before coming to Harvard I spent three years at Colorado School of Mines studying
        engineering physics, where I got to build solid-state lasers from scratch, violate
        the Bell inequality with entangled photon pairs, and design photon-counting
        circuits on an FPGA. These days I'm reading a lot about quantum information, quantum networks and photonic
        interconnects, and entanglement distribution between spin-based quantum
        nodes, and I'm applying to physics PhD programs for Fall 2027.
      </p>

      <div class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <a href="https://scholar.google.com/citations?user=gr1ZNUAAAAAJ&hl=en" target="_blank" rel="noopener noreferrer" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">Google Scholar</a>
        <a href="https://orcid.org/0009-0007-9290-6289" target="_blank" rel="noopener noreferrer" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">ORCID</a>
        <a href="https://github.com/itgall" target="_blank" rel="noopener noreferrer" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">GitHub</a>
        <a href="https://linkedin.com/in/isaactgallegos" target="_blank" rel="noopener noreferrer" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">LinkedIn</a>
        <a href="mailto:itgall@mit.edu" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] transition-colors no-underline">Email</a>
      </div>

    </div>
  </section>

  {/* ═══════ TRAJECTORY: reverse-chronological timeline ═════════════ */}
  <section class="about-section">
    <div class="about-inner">

      <h2 class="mb-8 font-mono text-[11px] font-medium uppercase tracking-wider text-[var(--color-muted)]">
        Trajectory
      </h2>

      <ol class="timeline">
        {timeline.map((entry) => (
          <li class:list={["timeline-entry", entry.future && "timeline-entry-future"]}>
            <div class="timeline-period font-mono">
              {entry.period}
            </div>
            <div class="timeline-content">
              <h3 class="timeline-role">
                {entry.role}
                {entry.current && <span class="timeline-badge">Current</span>}
              </h3>
              <p class="timeline-institution">
                {entry.institution}
              </p>
              {entry.description && (
                <p class="timeline-description">
                  {entry.description}
                </p>
              )}
            </div>
          </li>
        ))}
      </ol>

    </div>
  </section>

  {/* ═══════ LEARN MORE: compact link row ═══════════════════════════ */}
  <section class="about-section about-section-alt">
    <div class="about-inner">

      <h2 class="mb-5 font-mono text-[11px] font-medium uppercase tracking-wider text-[var(--color-muted)]">
        Learn more
      </h2>
      <div class="flex flex-wrap gap-3">
        <a
          href="/cv/"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-accent-border)] px-5 py-2.5 font-mono text-sm text-[var(--color-accent)] transition-colors hover:bg-[var(--color-accent-bg)] no-underline"
        >
          View CV →
        </a>
        <a
          href="/publications/"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-2.5 font-mono text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-bg-off)] no-underline"
        >
          Publications →
        </a>
        <a
          href="/projects/"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-2.5 font-mono text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-bg-off)] no-underline"
        >
          Research →
        </a>
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-2.5 font-mono text-sm text-[var(--color-text-secondary)] transition-colors hover:bg-[var(--color-bg-off)] no-underline"
        >
          Essays →
        </a>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /*
   * ALTERNATING FULL-WIDTH SECTIONS (whitespace management)
   *
   * Each <section class="about-section"> spans the full viewport width.
   * The background color alternates (default / off) to create visual rhythm
   * between sections. Content is constrained to 760px inside each section
   * via .about-inner. This technique — the highest-impact whitespace solution
   * identified in the research — makes the narrow reading column feel
   * intentional within a larger visual system rather than sparse.
   */
  .about-section {
    padding: 3rem 1.5rem;
    background: var(--color-bg);
  }

  .about-section-alt {
    background: var(--color-bg-off);
  }

  .about-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .about-section {
      padding: 4rem 2rem;
    }
  }

  /*
   * TIMELINE
   *
   * Two-column grid: fixed-width period column on the left, flexible content
   * column on the right. A subtle left border on the content column creates
   * visual rhythm and connects entries into a vertical flow without needing
   * explicit dots/lines that clutter the layout.
   *
   * On mobile, the grid collapses so the period stacks above the content.
   */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .timeline-period {
    font-size: 12px;
    color: var(--color-muted);
    padding-top: 2px;
    letter-spacing: 0.02em;
  }

  .timeline-content {
    border-left: 2px solid var(--color-border);
    padding-left: 1.25rem;
  }

  .timeline-entry-future .timeline-content {
    border-left-style: dashed;
    opacity: 0.85;
  }

  .timeline-role {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .timeline-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }

  .timeline-institution {
    font-size: 13px;
    color: var(--color-muted);
    margin: 4px 0 0;
  }

  .timeline-description {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 10px 0 0;
    line-height: 1.65;
  }

  /* ── Mobile: single block, MUST come last to win the cascade ── */
  @media (max-width: 640px) {
    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .timeline-content {
      border-left: none;
      padding-left: 0;
    }
    .timeline-entry-future .timeline-content {
      border-left: none;
      opacity: 1;
    }
  }
</style>
