---
/**
 * about.astro -- About page (Pattern 1: hero + chronological timeline).
 *
 * Architecture:
 *   Full-width alternating background sections with constrained content width.
 *   Each <section> spans the full viewport; the inner <.about-inner> constrains
 *   content to 760px. This eliminates the "narrow column floating in empty space"
 *   problem on wide screens while keeping reading line length optimal.
 *
 * Structure:
 *   1. Hero -- fixed "About" label + editable tagline
 *   2. Bio -- one editable paragraph (inline markdown) + identity link row
 *   3. Trajectory -- editable reverse-chronological timeline
 *   4. Learn more -- fixed CV / publications / research links row
 *
 * Content lives in src/data/about.json (edited in the CMS under
 * Pages -> About, read defensively by src/data/about.ts). The social links
 * come from the site-wide identity source in src/data/meta.ts, so a change
 * there propagates here automatically.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import { bio, metaDescription, tagline, timeline } from "@data/about";
import { identity } from "@data/meta";
import { renderInlineMarkdown } from "@utils/markdown";
---

<BaseLayout title="About" activeNav="about" description={metaDescription}>
  {/* ======= HERO: identity, tagline ======= */}
  <section class="about-section">
    <div class="about-inner">
      <div class="max-w-2xl">
        <h1 class="vt-page-title sc-label text-[12px] text-[var(--color-muted)]">About</h1>

        <p
          class="mt-4 text-[22px] leading-[1.5] text-[var(--color-text-secondary)] italic md:text-[24px]"
        >
          {tagline}
        </p>
      </div>
    </div>
  </section>

  {/* ======= BIO: one paragraph + identity links ======= */}
  <section class="about-section about-section-alt">
    <div class="about-inner">
      <p
        class="text-[16px] leading-[1.78] text-[var(--color-text-secondary)]"
        set:html={renderInlineMarkdown(bio)}
      />

      <div class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <a
          href={identity.googleScholar}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-link)] no-underline transition-colors hover:text-[var(--color-link-hover)]"
          >Google Scholar</a
        >
        <a
          href={`https://orcid.org/${identity.orcid}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-link)] no-underline transition-colors hover:text-[var(--color-link-hover)]"
          >ORCID</a
        >
        <a
          href={identity.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-link)] no-underline transition-colors hover:text-[var(--color-link-hover)]"
          >GitHub</a
        >
        <a
          href={identity.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-link)] no-underline transition-colors hover:text-[var(--color-link-hover)]"
          >LinkedIn</a
        >
        <a
          href={`mailto:${identity.email}`}
          class="text-[var(--color-link)] no-underline transition-colors hover:text-[var(--color-link-hover)]"
          >Email</a
        >
      </div>
    </div>
  </section>

  {/* ======= TRAJECTORY: reverse-chronological timeline ======= */}
  <section class="about-section">
    <div class="about-inner">
      <h2 class="sc-label mb-8 text-[12px] text-[var(--color-muted)]">Trajectory</h2>

      <ol class="timeline">
        {
          timeline.map((entry) => (
            <li class:list={["timeline-entry", entry.future && "timeline-entry-future"]}>
              <div class="timeline-period font-mono">{entry.period}</div>
              <div class="timeline-content">
                <h3 class="timeline-role">
                  {entry.role}
                  {entry.current && <span class="timeline-badge">Current</span>}
                </h3>
                <p class="timeline-institution">{entry.institution}</p>
                {entry.description && <p class="timeline-description">{entry.description}</p>}
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* ======= LEARN MORE: compact link row ======= */}
  <section class="about-section about-section-alt">
    <div class="about-inner">
      <h2 class="sc-label mb-5 text-[12px] text-[var(--color-muted)]">Learn more</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href="/cv/"
          class="sc-label inline-flex items-center gap-2 rounded-md border border-[var(--color-accent-border)] px-5 py-2.5 text-[11.5px] text-[var(--color-accent)] no-underline transition-colors hover:bg-[var(--color-accent-bg)]"
        >
          View CV &rarr;
        </a>
        <a
          href="/publications/"
          class="sc-label inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-2.5 text-[11.5px] text-[var(--color-text-secondary)] no-underline transition-colors hover:bg-[var(--color-bg-off)]"
        >
          Publications &rarr;
        </a>
        <a
          href="/projects/"
          class="sc-label inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-2.5 text-[11.5px] text-[var(--color-text-secondary)] no-underline transition-colors hover:bg-[var(--color-bg-off)]"
        >
          Research &rarr;
        </a>
        <a
          href="/blog/"
          class="sc-label inline-flex items-center gap-2 rounded-md border border-[var(--color-border)] px-5 py-2.5 text-[11.5px] text-[var(--color-text-secondary)] no-underline transition-colors hover:bg-[var(--color-bg-off)]"
        >
          Essays &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /*
   * ALTERNATING FULL-WIDTH SECTIONS (whitespace management)
   *
   * Each <section class="about-section"> spans the full viewport width.
   * The background color alternates (default / off) to create visual rhythm
   * between sections. Content is constrained to 760px inside each section
   * via .about-inner. This technique -- the highest-impact whitespace solution
   * identified in the research -- makes the narrow reading column feel
   * intentional within a larger visual system rather than sparse.
   */
  .about-section {
    padding: 3rem 1.5rem;
    background: var(--color-bg);
  }

  .about-section-alt {
    background: var(--color-bg-off);
  }

  .about-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .about-section {
      padding: 4rem 2rem;
    }
  }

  /*
   * TIMELINE
   *
   * Two-column grid: fixed-width period column on the left, flexible content
   * column on the right. A subtle left border on the content column creates
   * visual rhythm and connects entries into a vertical flow without needing
   * explicit dots/lines that clutter the layout.
   *
   * On mobile, the grid collapses so the period stacks above the content.
   */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .timeline-period {
    font-size: 12px;
    color: var(--color-muted);
    padding-top: 2px;
    letter-spacing: 0.02em;
  }

  .timeline-content {
    border-left: 2px solid var(--color-border);
    padding-left: 1.25rem;
  }

  .timeline-entry-future .timeline-content {
    border-left-style: dashed;
    opacity: 0.85;
  }

  .timeline-role {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .timeline-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }

  .timeline-institution {
    font-size: 13px;
    color: var(--color-muted);
    margin: 4px 0 0;
  }

  .timeline-description {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 10px 0 0;
    line-height: 1.65;
  }

  /* -- Mobile: single block, MUST come last to win the cascade -- */
  @media (max-width: 640px) {
    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .timeline-content {
      border-left: none;
      padding-left: 0;
    }
    .timeline-entry-future .timeline-content {
      border-left: none;
      opacity: 1;
    }
  }
</style>
