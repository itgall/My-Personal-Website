{
  "name": "isaac-gallegos-website",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Source for isaac-gallegos.com, my personal and academic website.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,css,md,mdx}\"",
    "new:post": "tsx scripts/new-post.ts",
    "new:project": "tsx scripts/new-project.ts",
    "new:note": "tsx scripts/new-note.ts",
    "refresh:citations": "tsx scripts/refresh-citations.ts"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/react": "5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource/inter": "^5.3.0",
    "@retorquere/bibtex-parser": "^9.0.29",
    "@tailwindcss/vite": "4.3.3",
    "@types/d3": "^7.4.3",
    "@types/hast": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "6.4.8",
    "d3": "^7.9.0",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.7",
    "netlify-plugin-cache": "^1.0.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-math": "^6.0.0",
    "satori": "^0.28.2",
    "sharp": "^0.35.3",
    "slugify": "^1.6.9",
    "tailwindcss": "4.3.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tsx": "^4.23.1",
    "typescript": "6.0.2"
  },
  "overrides": {
    "vite": "^7.3.4",
    "sharp": "^0.35.3"
  }
}
